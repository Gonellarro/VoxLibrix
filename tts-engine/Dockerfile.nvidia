# Imagen base con soporte CUDA para NVIDIA
FROM nvidia/cuda:12.1.1-devel-ubuntu22.04

# Evitar prompts interactivos
ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Instalar Python y dependencias de sistema para audio
RUN apt-get update && apt-get install -y \
    python3.10 \
    python3-pip \
    libsndfile1 \
    ffmpeg \
    sox \
    libsox-fmt-all \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Crear usuario para que coincidan permisos (1000:1000)
RUN groupadd -g 1000 vox && \
    useradd -u 1000 -g vox -m vox && \
    chown vox:vox /app

# Instalar PyTorch con soporte CUDA 12.1 (el mismo que usamos en Modal)
RUN pip3 install --no-cache-dir \
    torch torchaudio --index-url https://download.pytorch.org/whl/cu121

# Instalar el resto de dependencias de Qwen
RUN pip3 install --no-cache-dir \
    qwen-tts \
    soundfile \
    fastapi \
    uvicorn[standard] \
    python-multipart \
    accelerate \
    transformers

# Copiar el mismo servidor que el motor AMD
COPY servidor_tts.py .

# El modelo se descarga en /models (montado como volumen)
ENV HF_HOME=/models
ENV DEVICE=cuda:0
ENV DTYPE=bfloat16

EXPOSE 8000

# Ejecutar como usuario vox
USER vox

CMD ["uvicorn", "servidor_tts:app", "--host", "0.0.0.0", "--port", "8000"]
